# CloudGuard Pro — Environment Configuration v2.5
# Copy this to .env and fill in your values

# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── AWS SSO ─────────────────────────────────────────────
AWS_SSO_START_URL=https://d-9066009340.awsapps.com/start
AWS_SSO_REGION=us-east-1

# ── Session ─────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=gag903536@gmail.com
SMTP_PASS=rrkx fump lqsr xonp
SMTP_FROM=CloudGuard Pro <no-reply gag903536@gmail.com>

# Who receives all CloudGuard alerts
ALERT_EMAIL=gag903536@gmail.com,gaganlkklr2006@gmail.com




# ── App URL (used in email links) ────────────────────────────────────────────
APP_URL=http://localhost:4000

# ── Cost Alert Threshold ─────────────────────────────────────────────────────
# Send email alert when monthly spend exceeds this USD amount
COST_ALERT_THRESHOLD=500

# ── Absence Management ───────────────────────────────────────────────────────
# Number of days of inactivity before auto-stopping AWS services
MAX_ABSENT_DAYS=5
